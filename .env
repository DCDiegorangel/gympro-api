# ─────────────────────────────────────────────
#  GymPro — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# ── Banco de dados (PostgreSQL) ──────────────
DB_USER=postgres
DB_PASSWORD=@Mudar1234
DB_HOST=localhost
DB_PORT=5432
DB_NAME=academia_db

# ── JWT ──────────────────────────────────────
# Gere um valor forte em produção:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=seu-segredo-super-seguro-aqui-mude-em-producao

# ── Mercado Pago ─────────────────────────────
# Substitua pelos tokens de PRODUÇÃO antes do go-live
# Mercado Pago - PRODUÇÃO
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-5773533544638595-040608-8925257c8554671a2164c19cb531e23e-275893456
MERCADO_PAGO_PUBLIC_KEY=APP_USR-926e38bd-5839-43ff-8f27-ba07ed5f1b94

# ── URLs ─────────────────────────────────────
# Em desenvolvimento com ngrok, use a URL do túnel
# Em produção, use o domínio real (https://meusite.com)
API_URL=https://dane-repudiatory-unsoberly.ngrok-free.dev/api
FRONTEND_URL=https://dane-repudiatory-unsoberly.ngrok-free.dev

# ── Servidor ─────────────────────────────────
PORT=3001
NODE_ENV=development

# ── E-mail (opcional — para notificações) ────
# Para Gmail: crie uma "Senha de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app
SMTP_FROM=noreply@gympro.com